# Discord
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=
DISCORD_DEV_GUILD_ID=
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# Optional legacy alias if your setup expects it
NEXTAUTH_SECRET=

# Database
DATABASE_URL=postgresql://kaoru:kaoru@localhost:5432/kaoru

# Redis
REDIS_URL=redis://localhost:6379

# Bot Config
DEFAULT_PREFIX=k!
SUMMON_COOLDOWN_SEC=1200
GRAB_COOLDOWN_SEC=600
ACTIVITY_SPAWN_THRESHOLD=15
MYSTERY_CARD_CHANCE=0.05

# Dev (bypass cooldowns)
DEV_USER_IDS=
ENABLE_PRIVATE_ADMIN_REVIEW=0
ENABLE_UNVERIFIED_VOTE_REWARDS=0
VOTE_URL=

# Web admin: map Discord guild roles → admin_users (run: npm run sync:admin-discord)
# Bot needs Server Members Intent. At least one ADMIN_SYNC_ROLE_* must be set.
ADMIN_SYNC_GUILD_ID=
ADMIN_SYNC_ROLE_OWNER=
ADMIN_SYNC_ROLE_ADMIN=
ADMIN_SYNC_ROLE_CURATOR=
ADMIN_SYNC_ROLE_VIEWER=
# Remove discord_sync admins not in the last full sync (non-owners only)
ADMIN_SYNC_PRUNE=

# Testing
ALT_TOKEN=
TEST_CHANNEL_ID=

# Image Storage
IMAGE_DIR=./data/images
CARD_CACHE_DIR=./data/cache
